TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_WEBHOOK_SECRET=optional-secret
DEFAULT_MODEL=claude

# 아래 3개는 "초기 1회 프로젝트 레지스트리 시드" 용도입니다.
# PROJECTS_CONFIG_PATH가 이미 존재하면 해당 파일 설정이 우선됩니다.
DEFAULT_PROJECT=remote-coder
PROJECT_ROOT=/Users/yourname/Git/remote-coder
WORKTREE_BASE_DIR=/Users/yourname/Git/remote-coder-worktrees
JOB_TIMEOUT_SECONDS=1800
KEEP_WORKTREE_ON_SUCCESS=true

# Git 원격 이름 (push /rebase /clear 시 사용). 기본 origin
# GIT_REMOTE_NAME=origin

# 선택: 프로젝트 등록 JSON/YAML 경로. 미설정 시 PROJECT_ROOT/.remote-coder/projects.json 사용
# PROJECTS_CONFIG_PATH=/path/to/projects.json
